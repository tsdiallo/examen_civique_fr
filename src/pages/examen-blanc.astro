---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Examen blanc — Examen civique">
  <section class="container-page py-10">
    <h1 class="text-3xl font-display">Examen blanc</h1>
    <p class="text-ink-700 mt-2 max-w-prose">
      40 questions originales, 45 minutes, seuil de réussite indicatif de 32/40.
      À lancer dans le calme, comme une vraie session.
    </p>
    <div class="card p-6 mt-6 text-ink-500 text-sm">L'examen blanc sera disponible en phase 6.</div>
  </section>
</BaseLayout>
