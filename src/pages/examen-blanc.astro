---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExamRunner from "../components/exam/ExamRunner.astro";
import Alert from "../components/ui/Alert.astro";
import { getCollection } from "astro:content";
import { getExam } from "../lib/quiz-loader";

const exam = await getExam();
const themes = await getCollection("themes");
const themeTitles: Record<string, string> = Object.fromEntries(
  themes.map((t) => [t.slug, t.data.title])
);
---
<BaseLayout title="Examen blanc — Examen civique">
  <section class="container-page pt-12 pb-6">
    <p class="eyebrow">Conditions réelles</p>
    <h1 class="mt-4 font-display text-display-sm sm:text-display text-balance">
      Examen <span class="text-gradient">blanc</span>.
    </h1>
    <p class="mt-5 max-w-2xl text-ink-700 text-pretty">
      Entraînez-vous dans des conditions proches de l'examen réel : <strong>{exam?.total ?? 40} questions</strong>,
      <strong>{Math.round((exam?.durationSec ?? 2700) / 60)} minutes</strong>, seuil indicatif <strong>{exam?.passingScore ?? 32}/{exam?.total ?? 40}</strong>.
    </p>
  </section>

  <section class="container-page pb-20">
    {exam
      ? <ExamRunner exam={exam} themeTitles={themeTitles} />
      : <Alert tone="info" title="Examen en préparation">L'examen blanc sera ajouté en phase 6.</Alert>
    }
  </section>
</BaseLayout>
