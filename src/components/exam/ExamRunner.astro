---
import type { ExamPayload } from "../../lib/types";

interface Props {
  exam: ExamPayload;
  themeTitles: Record<string, string>;
}
const { exam, themeTitles } = Astro.props;
const payload = JSON.stringify({ exam, themeTitles });
---
<section class="exam-root" data-exam={payload} aria-live="polite">
  <!-- Intro -->
  <div class="card-france p-5 sm:p-8" data-ex-intro>
    <p class="eyebrow">Conditions réelles</p>
    <h1 class="mt-3 font-display text-3xl sm:text-4xl text-ink-900">Examen blanc</h1>
    <p class="text-ink-700 mt-3 max-w-prose">
      <strong>{exam.total} questions</strong> · {Math.round(exam.durationSec / 60)} minutes · seuil indicatif de réussite <strong>{exam.passingScore}/{exam.total}</strong>.
      Une fois l'examen démarré, le chronomètre ne s'arrête pas.
    </p>
    <ul class="mt-5 grid gap-3 sm:grid-cols-3">
      <li class="rounded-2xl bg-white border border-paper-300 p-4 text-sm">
        <p class="text-xs uppercase tracking-[0.16em] text-ink-500 font-semibold">Étape 1</p>
        <p class="mt-1 text-ink-800">Répondez à chaque question, passez à la suivante.</p>
      </li>
      <li class="rounded-2xl bg-white border border-paper-300 p-4 text-sm">
        <p class="text-xs uppercase tracking-[0.16em] text-ink-500 font-semibold">Étape 2</p>
        <p class="mt-1 text-ink-800">Revenez en arrière pour modifier si besoin.</p>
      </li>
      <li class="rounded-2xl bg-white border border-paper-300 p-4 text-sm">
        <p class="text-xs uppercase tracking-[0.16em] text-ink-500 font-semibold">Étape 3</p>
        <p class="mt-1 text-ink-800">Recevez une correction détaillée par thème.</p>
      </li>
    </ul>
    <button type="button" class="btn-primary btn-lg mt-7 w-full sm:w-auto justify-center" data-ex-start>
      Commencer l'examen
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </button>
  </div>

  <!-- En cours -->
  <div class="card p-5 sm:p-7 hidden" data-ex-play>
    <div class="flex items-center justify-between gap-3 text-sm">
      <span class="font-semibold text-ink-700 tabular-nums" data-ex-progress>Question 1 / {exam.total}</span>
      <span class="inline-flex items-center gap-2 rounded-full bg-france-50 ring-1 ring-france-200 px-3 py-1 font-mono font-semibold text-france-700 tabular-nums" data-ex-timer>
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        45:00
      </span>
    </div>
    <div class="mt-3 h-1.5 rounded-full bg-paper-200 overflow-hidden">
      <div class="h-full bg-france-700 transition-[width] duration-300" style="width: 0%" data-ex-bar></div>
    </div>

    <p class="mt-5 text-xs uppercase tracking-[0.16em] text-france-700 font-semibold" data-ex-theme></p>
    <h2 class="mt-1 text-xl sm:text-2xl font-display text-ink-900 text-pretty leading-snug" data-ex-prompt></h2>

    <fieldset class="mt-6 space-y-2.5" data-ex-choices>
      <legend class="sr-only">Choisissez une réponse</legend>
    </fieldset>

    <div class="mt-7 flex items-center justify-between gap-2 flex-wrap">
      <button type="button" class="btn-ghost" data-ex-prev>← Précédent</button>
      <div class="flex gap-2 ml-auto">
        <button type="button" class="btn-secondary" data-ex-next>Suivant →</button>
        <button type="button" class="btn-marianne hidden" data-ex-finish>Terminer</button>
      </div>
    </div>

    <p class="mt-4 text-xs text-ink-500"><span class="tabular-nums" data-ex-answered>0</span> / {exam.total} répondues</p>
  </div>

  <!-- Résultat -->
  <div class="card p-5 sm:p-7 mt-0 hidden" data-ex-result>
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <p data-ex-verdict class="badge">Résultat</p>
        <h2 class="font-display text-3xl sm:text-4xl mt-3">
          <span class="text-france-700 tabular-nums" data-ex-score>0</span><span class="text-ink-500">/</span><span class="tabular-nums">{exam.total}</span>
        </h2>
        <p class="text-ink-700 mt-2 max-w-prose" data-ex-feedback></p>
      </div>
      <p class="text-sm text-ink-500">Temps utilisé : <span class="tabular-nums font-medium text-ink-800" data-ex-time-used>—</span></p>
    </div>

    <div class="mt-5">
      <div class="h-2 rounded-full bg-paper-200 overflow-hidden">
        <div class="h-full transition-[width] duration-500" style="width: 0%" data-ex-score-bar></div>
      </div>
    </div>

    <h3 class="mt-8 font-display text-xl">Résultats par thème</h3>
    <ul class="mt-4 space-y-3.5" data-ex-breakdown></ul>

    <h3 class="mt-8 font-display text-xl">Recommandations</h3>
    <ul class="mt-3 list-none pl-0 space-y-2 text-sm text-ink-800" data-ex-reco></ul>

    <details class="mt-8 group">
      <summary class="cursor-pointer font-semibold text-france-700 inline-flex items-center gap-2 select-none">
        <svg class="w-4 h-4 transition-transform group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        Voir la correction détaillée
      </summary>
      <ol class="mt-5 space-y-5" data-ex-corrections></ol>
    </details>

    <div class="mt-8 flex flex-col sm:flex-row flex-wrap gap-3">
      <button type="button" class="btn-primary justify-center" data-ex-retry>Refaire un examen</button>
      <a href="/themes" class="btn-secondary justify-center">Réviser mes thèmes faibles</a>
    </div>
  </div>
</section>

<script>
  import { saveExamAttempt } from "../../lib/progress";
  import { computeScore, weakThemes, type Answer } from "../../lib/scoring";
  import { shuffle } from "../../lib/shuffle";
  import type { ExamPayload, Question, ChoiceId } from "../../lib/types";

  const root = document.querySelector<HTMLElement>(".exam-root")!;
  const data = JSON.parse(root.dataset.exam || "{}") as {
    exam: ExamPayload;
    themeTitles: Record<string, string>;
  };
  const exam = data.exam;
  const titles = data.themeTitles;

  const $ = <T extends HTMLElement = HTMLElement>(name: string) =>
    root.querySelector<T>(`[data-ex-${name}]`)!;

  const els = {
    intro: $("intro"), play: $("play"), result: $("result"),
    start: $("start") as HTMLButtonElement,
    progress: $("progress"), timer: $("timer"),
    bar: $("bar"), theme: $("theme"), prompt: $("prompt"),
    choices: $("choices") as HTMLFieldSetElement,
    prev: $("prev") as HTMLButtonElement,
    next: $("next") as HTMLButtonElement,
    finish: $("finish") as HTMLButtonElement,
    answered: $("answered"),
    verdict: $("verdict"), score: $("score"), feedback: $("feedback"),
    timeUsed: $("time-used"), scoreBar: $("score-bar"),
    breakdown: $("breakdown") as HTMLUListElement,
    reco: $("reco") as HTMLUListElement,
    corrections: $("corrections") as HTMLOListElement,
    retry: $("retry") as HTMLButtonElement,
  };

  let questions: Question[] = [];
  let selected: (ChoiceId | null)[] = [];
  let index = 0;
  let startedAt = 0;
  let endAt = 0;
  let timerId: number | null = null;
  let finished = false;

  function startExam() {
    questions = shuffle(exam.questions).slice(0, exam.total);
    selected = questions.map(() => null);
    index = 0;
    finished = false;
    startedAt = Date.now();
    endAt = startedAt + exam.durationSec * 1000;
    els.intro.classList.add("hidden");
    els.play.classList.remove("hidden");
    els.result.classList.add("hidden");
    render();
    tickTimer();
    timerId = window.setInterval(tickTimer, 1000);
  }

  function tickTimer() {
    const remaining = Math.max(0, endAt - Date.now());
    const m = Math.floor(remaining / 60000);
    const s = Math.floor((remaining % 60000) / 1000);
    els.timer.textContent = `${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
    if (remaining <= 0 && !finished) finishExam(true);
  }

  function render() {
    const q = questions[index];
    els.progress.textContent = `Question ${index + 1} / ${exam.total}`;
    els.prompt.textContent = q.prompt;
    els.theme.textContent = (q.themeSlug && titles[q.themeSlug]) ? titles[q.themeSlug] : "";
    els.bar.style.width = `${((index) / exam.total) * 100}%`;
    els.answered.textContent = String(selected.filter(Boolean).length);

    els.choices.innerHTML = "";
    q.choices.forEach((c) => {
      const label = document.createElement("label");
      label.className = "flex items-start gap-3 p-4 rounded-2xl border border-paper-300 bg-white transition-all duration-150 hover:border-france-400 hover:bg-france-50/40 cursor-pointer has-[:checked]:border-france-700 has-[:checked]:bg-france-50";
      label.innerHTML = `
        <input type="radio" name="q-${q.id}" value="${c.id}" class="mt-1 accent-france-700" ${selected[index] === c.id ? "checked" : ""} />
        <span class="text-ink-900 leading-relaxed"><span class="font-display font-semibold text-france-700 mr-2">${c.id.toUpperCase()}.</span>${c.text}</span>
      `;
      const input = label.querySelector<HTMLInputElement>("input")!;
      input.addEventListener("change", () => {
        selected[index] = input.value as ChoiceId;
        els.answered.textContent = String(selected.filter(Boolean).length);
      });
      els.choices.appendChild(label);
    });

    els.prev.disabled = index === 0;
    const last = index === exam.total - 1;
    els.next.classList.toggle("hidden", last);
    els.finish.classList.toggle("hidden", !last);
  }

  els.start.addEventListener("click", startExam);
  els.prev.addEventListener("click", () => { if (index > 0) { index -= 1; render(); } });
  els.next.addEventListener("click", () => { if (index < exam.total - 1) { index += 1; render(); } });
  els.finish.addEventListener("click", () => finishExam(false));
  els.retry.addEventListener("click", () => {
    els.result.classList.add("hidden");
    els.intro.classList.remove("hidden");
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  function finishExam(timeOut: boolean) {
    if (finished) return;
    finished = true;
    if (timerId) { clearInterval(timerId); timerId = null; }

    const answers: Answer[] = questions.map((q, i) => ({ questionId: q.id, selected: selected[i] }));
    const result = computeScore(questions, answers, exam.passingScore);
    const weak = weakThemes(result);
    saveExamAttempt(result.correct, weak);

    const used = Math.min(exam.durationSec, Math.floor((Date.now() - startedAt) / 1000));
    const m = Math.floor(used / 60), s = used % 60;

    els.score.textContent = String(result.correct);
    els.verdict.textContent = result.passed ? "Réussi" : (timeOut ? "Temps écoulé" : "Non atteint");
    els.verdict.className = `inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] ${result.passed ? "bg-success-50 text-success-700 ring-1 ring-success-100" : "bg-marianne-50 text-marianne-500 ring-1 ring-marianne-200"}`;
    els.feedback.textContent = result.passed
      ? `Bravo, vous avez franchi le seuil indicatif de ${exam.passingScore}/${exam.total}.`
      : `Il manque ${Math.max(0, exam.passingScore - result.correct)} bonne(s) réponse(s) pour atteindre le seuil indicatif.`;
    els.timeUsed.textContent = `${m} min ${s.toString().padStart(2, "0")} s`;
    const pct = (result.correct / exam.total) * 100;
    els.scoreBar.style.width = `${pct}%`;
    (els.scoreBar as HTMLElement).className = `h-full transition-[width] duration-500 ${result.passed ? "bg-success-600" : "bg-marianne-400"}`;

    // Breakdown
    els.breakdown.innerHTML = "";
    Object.entries(result.byTheme)
      .sort(([a], [b]) => (titles[a] || a).localeCompare(titles[b] || b))
      .forEach(([slug, v]) => {
        const pc = v.total ? Math.round((v.correct / v.total) * 100) : 0;
        const tone = pc >= 70 ? "bg-success-600" : pc >= 50 ? "bg-warning-600" : "bg-marianne-400";
        const li = document.createElement("li");
        li.innerHTML = `
          <div class="flex justify-between text-sm">
            <span class="text-ink-900 font-medium">${titles[slug] || slug}</span>
            <span class="text-ink-500 tabular-nums">${v.correct}/${v.total}</span>
          </div>
          <div class="h-1.5 rounded-full bg-paper-200 overflow-hidden mt-1.5"><div class="h-full ${tone}" style="width:${pc}%"></div></div>
        `;
        els.breakdown.appendChild(li);
      });

    // Recommendations
    els.reco.innerHTML = "";
    const recos = weak.slice(0, 3).map((slug) => {
      const t = titles[slug] || slug;
      return `Revoir la fiche <a class="text-france-700 underline decoration-france-300 underline-offset-2" href="/themes/${slug}">${t}</a> puis refaire son quiz.`;
    });
    if (recos.length === 0) recos.push("Maintenez le rythme : refaites un examen blanc pour consolider.");
    recos.forEach((r) => {
      const li = document.createElement("li");
      li.className = "relative pl-6 before:absolute before:left-0 before:top-[0.55em] before:w-1.5 before:h-1.5 before:rounded-full before:bg-france-700";
      li.innerHTML = r;
      els.reco.appendChild(li);
    });

    // Corrections
    els.corrections.innerHTML = "";
    questions.forEach((q, i) => {
      const ok = selected[i] === q.answer;
      const correctText = q.choices.find((c) => c.id === q.answer)?.text || "";
      const pickedText = q.choices.find((c) => c.id === selected[i])?.text || "Pas de réponse";
      const li = document.createElement("li");
      li.className = "rounded-2xl border bg-white p-4 sm:p-5 " + (ok ? "border-success-100" : "border-marianne-200");
      li.innerHTML = `
        <p class="text-xs uppercase tracking-[0.16em] font-semibold ${ok ? "text-success-700" : "text-marianne-500"}">Question ${i + 1} · ${ok ? "Correct" : "À revoir"}</p>
        <p class="mt-1 text-xs text-ink-500">${titles[q.themeSlug || ""] || ""}</p>
        <p class="mt-2 font-medium text-ink-900">${q.prompt}</p>
        <p class="text-sm mt-2 text-ink-700">Votre réponse : <strong class="text-ink-900">${pickedText}</strong></p>
        ${ok ? "" : `<p class="text-sm text-ink-700">Bonne réponse : <strong class="text-success-700">${correctText}</strong></p>`}
        <p class="text-sm text-ink-700 mt-2 leading-relaxed">${q.explanation}</p>
      `;
      els.corrections.appendChild(li);
    });

    els.play.classList.add("hidden");
    els.result.classList.remove("hidden");
    els.result.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  window.addEventListener("beforeunload", (e) => {
    if (!finished && startedAt > 0) { e.preventDefault(); e.returnValue = ""; }
  });
</script>
