---
interface Props {
  order: number;
  title: string;
  summary: string;
  durationMin: number;
  tags?: string[];
}
const { order, title, summary, durationMin, tags = [] } = Astro.props;
---
<header class="border-b border-ink-100 pb-6 mb-6">
  <p class="text-sm text-ink-500">Thème {order.toString().padStart(2, "0")} · {durationMin} min de lecture</p>
  <h1 class="mt-2 text-3xl sm:text-4xl font-display text-ink-900">{title}</h1>
  <p class="mt-3 text-ink-700 max-w-prose">{summary}</p>
  {tags.length > 0 && (
    <ul class="mt-4 flex flex-wrap gap-1.5">
      {tags.map((t) => <li class="badge">{t}</li>)}
    </ul>
  )}
</header>
