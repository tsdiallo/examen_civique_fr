---
interface Props {
  order: number;
  title: string;
  summary: string;
  durationMin: number;
  tags?: string[];
}
const { order, title, summary, durationMin, tags = [] } = Astro.props;
const num = order.toString().padStart(2, "0");
---
<header class="relative pb-8 mb-8 border-b border-paper-300">
  <div class="flex items-center gap-3">
    <span aria-hidden="true" class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-france-50 ring-1 ring-france-200 font-display text-france-700 text-lg tabular-nums">
      {num}
    </span>
    <div>
      <p class="text-xs uppercase tracking-[0.16em] text-ink-500 font-semibold">Fiche · Thème {num}</p>
      <p class="text-sm text-ink-600 mt-0.5">{durationMin} min de lecture</p>
    </div>
  </div>
  <h1 class="mt-6 font-display text-display-sm sm:text-display text-balance">{title}</h1>
  <p class="mt-4 text-lg text-ink-700 max-w-prose text-pretty">{summary}</p>
  {tags.length > 0 && (
    <ul class="mt-5 flex flex-wrap gap-1.5">
      {tags.map((t) => <li class="badge">{t}</li>)}
    </ul>
  )}
</header>
