---
interface Props {
  slug: string;
  questionsCount?: number;
}
const { slug, questionsCount } = Astro.props;
---
<aside class="mt-12 relative overflow-hidden card-france p-7 sm:p-8">
  <div aria-hidden="true" class="absolute -top-16 -right-16 w-48 h-48 rounded-full bg-france-700/10 blur-3xl"></div>
  <div class="relative flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5">
    <div>
      <p class="eyebrow">Vous tester</p>
      <h2 class="mt-3 font-display text-2xl text-ink-900">Prêt·e à vous tester ?</h2>
      <p class="text-sm text-ink-700 mt-2">
        {questionsCount ? `${questionsCount} questions` : "Quelques questions"} avec correction expliquée après chaque validation.
      </p>
    </div>
    <a href={`/quiz/${slug}`} class="btn-primary btn-lg shrink-0">
      Faire le quiz
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </div>
</aside>
