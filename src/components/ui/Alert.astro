---
interface Props {
  tone?: "info" | "success" | "warning" | "danger";
  title?: string;
}
const { tone = "info", title } = Astro.props;
const styles = {
  info:    "bg-brand-50 text-brand-900 border-brand-200",
  success: "bg-success-100 text-success-600 border-success-600/20",
  warning: "bg-warning-100 text-warning-600 border-warning-600/20",
  danger:  "bg-danger-100 text-danger-600 border-danger-600/20",
}[tone];
---
<div class={`border rounded-lg p-4 ${styles}`} role={tone === "danger" ? "alert" : "status"}>
  {title && <p class="font-semibold mb-1">{title}</p>}
  <div class="text-sm"><slot /></div>
</div>
