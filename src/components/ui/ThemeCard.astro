---
interface Props {
  slug: string;
  title: string;
  summary: string;
  order: number;
  durationMin: number;
  tags?: string[];
}
const { slug, title, summary, order, durationMin, tags = [] } = Astro.props;
---
<a href={`/themes/${slug}`} class="card p-5 no-underline block hover:border-brand-200 hover:shadow-md transition group">
  <div class="flex items-center justify-between text-xs text-ink-500">
    <span class="badge">Thème {order.toString().padStart(2, "0")}</span>
    <span>{durationMin} min</span>
  </div>
  <h3 class="mt-3 font-display text-xl text-ink-900 group-hover:text-brand-700">{title}</h3>
  <p class="mt-2 text-sm text-ink-700 leading-relaxed">{summary}</p>
  {tags.length > 0 && (
    <ul class="mt-3 flex flex-wrap gap-1.5">
      {tags.map((t) => <li class="badge">{t}</li>)}
    </ul>
  )}
  <span class="mt-4 inline-flex text-sm text-brand-600 group-hover:underline">Ouvrir la fiche →</span>
</a>
