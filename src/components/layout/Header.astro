---
const nav = [
  { href: "/", label: "Accueil" },
  { href: "/themes", label: "Thèmes" },
  { href: "/examen-blanc", label: "Examen blanc" },
  { href: "/a-propos", label: "À propos" },
];
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? current === "/" : current === href || current.startsWith(href + "/");
---
<header class="sticky top-0 z-40">
  <div class="stripe-tricolore" aria-hidden="true"></div>
  <div class="border-b border-paper-300 bg-paper-50/85 backdrop-blur-md supports-[backdrop-filter]:bg-paper-50/70">
    <div class="container-page flex items-center justify-between h-16">
      <a href="/" class="group flex items-center gap-3 no-underline">
        <span aria-hidden="true" class="relative inline-flex w-10 h-10 items-center justify-center rounded-xl bg-white border border-paper-300 shadow-soft overflow-hidden">
          <span class="absolute inset-x-0 top-0 h-1/3 bg-france-700"></span>
          <span class="absolute inset-x-0 bottom-0 h-1/3 bg-marianne-400"></span>
          <span class="relative font-display font-bold text-ink-900 text-base">EC</span>
        </span>
        <span class="flex flex-col leading-tight">
          <span class="font-display text-[1.05rem] font-semibold text-ink-900">Examen civique</span>
          <span class="text-[0.7rem] uppercase tracking-[0.16em] text-ink-500">Plateforme d'entraînement</span>
        </span>
      </a>
      <nav aria-label="Navigation principale">
        <ul class="flex items-center gap-1 text-sm">
          {nav.map((item) => {
            const active = isActive(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "relative px-3 py-2 rounded-full no-underline font-medium transition-colors",
                    active ? "text-france-700" : "text-ink-700 hover:text-france-700 hover:bg-paper-100"
                  ]}
                  aria-current={active ? "page" : undefined}
                >
                  {item.label}
                  {active && (
                    <span aria-hidden="true" class="absolute left-1/2 -translate-x-1/2 -bottom-0.5 h-[3px] w-6 rounded-full bg-france-700"></span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </div>
  </div>
</header>
