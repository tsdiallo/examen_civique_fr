---
const nav = [
  { href: "/", label: "Accueil" },
  { href: "/themes", label: "Thèmes" },
  { href: "/examen-blanc", label: "Examen blanc" },
  { href: "/a-propos", label: "À propos" },
];
const DONATION_URL = "https://buy.stripe.com/fZu4gy2ZodYJ8pEbxj7g400";
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? current === "/" : current === href || current.startsWith(href + "/");
---
<header class="sticky top-0 z-40">
  <div class="stripe-tricolore" aria-hidden="true"></div>
  <div class="border-b border-paper-300 bg-paper-50/85 backdrop-blur-md supports-[backdrop-filter]:bg-paper-50/70">
    <div class="container-page flex items-center justify-between gap-3 h-16">
      <a href="/" class="group flex items-center gap-2.5 sm:gap-3 no-underline min-w-0">
        <span aria-hidden="true" class="shrink-0 relative inline-flex w-9 h-9 sm:w-10 sm:h-10 items-center justify-center rounded-xl bg-white border border-paper-300 shadow-soft overflow-hidden">
          <span class="absolute inset-x-0 top-0 h-1/3 bg-france-700"></span>
          <span class="absolute inset-x-0 bottom-0 h-1/3 bg-marianne-400"></span>
          <span class="relative font-display font-semibold text-ink-900 text-[0.95rem] sm:text-base">EC</span>
        </span>
        <span class="flex flex-col leading-tight min-w-0">
          <span class="font-display text-[1.05rem] sm:text-[1.1rem] font-semibold text-ink-900 truncate">Examen civique</span>
          <span class="hidden sm:block text-[0.68rem] uppercase tracking-[0.16em] text-ink-500">Plateforme d'entraînement</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-4" aria-label="Navigation principale">
        <ul class="flex items-center gap-1 text-sm">
          {nav.map((item) => {
            const active = isActive(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "relative px-3 py-2 rounded-full no-underline font-medium transition-colors",
                    active ? "text-france-700" : "text-ink-700 hover:text-france-700 hover:bg-paper-100"
                  ]}
                  aria-current={active ? "page" : undefined}
                >
                  {item.label}
                  {active && (
                    <span aria-hidden="true" class="absolute left-1/2 -translate-x-1/2 -bottom-0.5 h-[3px] w-6 rounded-full bg-france-700"></span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
        <a
          href={DONATION_URL}
          rel="nofollow noopener"
          target="_blank"
          class="group inline-flex items-center gap-2 rounded-full bg-marianne-500 hover:bg-marianne-600 text-white text-sm font-semibold px-4 py-2 no-underline shadow-soft transition-colors"
          aria-label="Soutenir le site — paiement sécurisé par Stripe (ouvre un nouvel onglet)"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span>Soutenir</span>
        </a>
      </nav>

      <!-- Mobile toggle -->
      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full border border-paper-300 bg-white text-ink-800 hover:bg-paper-100"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-menu-btn
      >
        <svg class="w-5 h-5 block" data-menu-icon-open viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
        <svg class="w-5 h-5 hidden" data-menu-icon-close viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <nav
      id="mobile-nav"
      aria-label="Navigation mobile"
      class="md:hidden hidden border-t border-paper-300 bg-paper-50/95 backdrop-blur-md"
      data-menu-panel
    >
      <ul class="container-page py-3 flex flex-col">
        {nav.map((item) => {
          const active = isActive(item.href);
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  "flex items-center justify-between px-3 py-3 rounded-xl no-underline font-medium",
                  active ? "text-france-700 bg-france-50" : "text-ink-800 hover:bg-paper-100"
                ]}
                aria-current={active ? "page" : undefined}
              >
                <span>{item.label}</span>
                <svg class="w-4 h-4 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              </a>
            </li>
          );
        })}
        <li class="mt-2 px-3">
          <a
            href={DONATION_URL}
            rel="nofollow noopener"
            target="_blank"
            class="flex items-center justify-center gap-2 rounded-full bg-marianne-500 hover:bg-marianne-600 text-white font-semibold px-4 py-3 no-underline shadow-soft"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span>Soutenir le site</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-menu-btn]");
  const panel = document.querySelector<HTMLElement>("[data-menu-panel]");
  const openIcon = document.querySelector<SVGElement>("[data-menu-icon-open]");
  const closeIcon = document.querySelector<SVGElement>("[data-menu-icon-close]");
  if (btn && panel && openIcon && closeIcon) {
    btn.addEventListener("click", () => {
      const open = panel.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
      openIcon.classList.toggle("hidden", open);
      openIcon.classList.toggle("block", !open);
      closeIcon.classList.toggle("hidden", !open);
      closeIcon.classList.toggle("block", open);
    });
  }
</script>
